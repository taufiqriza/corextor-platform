APP_NAME=Corextor
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://api.corextor.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ──────────────────────────────────────────
# Database — Platform (default connection)
# ──────────────────────────────────────────
DB_CONNECTION=platform
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=corextor_platform
DB_USERNAME=root
DB_PASSWORD=

# ──────────────────────────────────────────
# Database — Attendance (product database)
# ──────────────────────────────────────────
DB_ATTENDANCE_HOST=127.0.0.1
DB_ATTENDANCE_PORT=3306
DB_ATTENDANCE_DATABASE=corextor_attendance
DB_ATTENDANCE_USERNAME=root
DB_ATTENDANCE_PASSWORD=

# ──────────────────────────────────────────
# Database — Payroll (product database)
# ──────────────────────────────────────────
DB_PAYROLL_HOST=127.0.0.1
DB_PAYROLL_PORT=3306
DB_PAYROLL_DATABASE=corextor_payroll
DB_PAYROLL_USERNAME=root
DB_PAYROLL_PASSWORD=

SESSION_DRIVER=array
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@corextor.com"
MAIL_FROM_NAME="${APP_NAME}"
