DB_PAYROLL_USERNAME=u435085854_corextor_payroll
DB_PAYROLL_PASSWORD=CHANGE_ME

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.corextor.com
REFRESH_COOKIE_DOMAIN=.corextor.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
CACHE_STORE=file

JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_TTL=900
JWT_REFRESH_TTL=604800

CORS_ALLOWED_ORIGINS=https://corextor.com,https://app.corextor.com

