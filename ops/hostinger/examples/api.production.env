APP_NAME=Corextor
APP_ENV=production
APP_KEY=base64:CHANGE_ME
APP_DEBUG=false
APP_URL=https://api.corextor.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

DB_CONNECTION=platform
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=u435085854_corextor_platform
DB_USERNAME=u435085854_corextor_platform
DB_PASSWORD=CHANGE_ME

DB_ATTENDANCE_HOST=127.0.0.1
DB_ATTENDANCE_PORT=3306
DB_ATTENDANCE_DATABASE=u435085854_corextor_attendance
DB_ATTENDANCE_USERNAME=u435085854_corextor_attendance
DB_ATTENDANCE_PASSWORD=CHANGE_ME

DB_PAYROLL_HOST=127.0.0.1
